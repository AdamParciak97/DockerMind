CT_USERNAME=admin
CT_PASSWORD=zmien-haslo-na-silne
CT_SECRET_KEY=losowy-klucz-minimum-32-znaki-zmien-to
AGENT_SECRET_TOKEN=tajny-token-agentow-min-32-znaki-zmien

# Generowanie silnych kluczy / tokenów: openssl rand -hex 32

# ── Email — wybierz SMTP lub Exchange (nie oba) ───────────────────────────────

# Exchange Online / Microsoft 365 (rekomendowane)
# Konfiguracja: Azure AD → App Registration → API permissions → Mail.Send (Application)
# EXCHANGE_ENABLED=false
# EXCHANGE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# EXCHANGE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# EXCHANGE_CLIENT_SECRET=twoj-client-secret
# EXCHANGE_SENDER=dockermind@firma.pl

# SMTP — opcjonalne, wymagane do wysyłki raportów emailem
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USER=twoj@gmail.com
# SMTP_PASSWORD=haslo-aplikacji
# SMTP_FROM=DockerMind <twoj@gmail.com>

# LDAP / Active Directory — opcjonalne
# LDAP_ENABLED=false
# LDAP_SERVER=192.168.1.10
# LDAP_PORT=389
# LDAP_USE_SSL=false          # true = LDAPS (port 636)
# LDAP_USE_TLS=false          # true = STARTTLS (port 389)
# LDAP_TLS_VERIFY=true        # false = nie weryfikuj certyfikatu (tylko dev!)
# LDAP_BIND_DN=cn=svc-dockermind,ou=service,dc=firma,dc=pl
# LDAP_BIND_PASSWORD=haslo-konta-serwisowego
# LDAP_BASE_DN=ou=users,dc=firma,dc=pl
# LDAP_USER_FILTER=(sAMAccountName={username})   # AD; OpenLDAP: (uid={username})
# LDAP_ADMIN_GROUP_DN=cn=dockermind-admins,ou=groups,dc=firma,dc=pl
